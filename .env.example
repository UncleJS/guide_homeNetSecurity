# NetInventory — environment (repo-local, copy to .env and fill in)
# This file is committed with PLACEHOLDERS only. The real .env is gitignored.

# ── Database (MariaDB) ──────────────────────────────────────────────
# The DB port is NOT published to the host; it is reachable only inside the pod.
MARIADB_DATABASE=netinventory
MARIADB_USER=netinventory
MARIADB_PASSWORD=change-me-strong-password
MARIADB_ROOT_PASSWORD=change-me-different-strong-password
# Containers in the SAME pod share a network namespace — reach the DB on localhost.
DB_HOST=127.0.0.1
DB_PORT=3306

# ── API (Elysia) ────────────────────────────────────────────────────
API_PORT=11291
# Comma-separated origins allowed by CORS (the web UI origin).
API_CORS_ORIGIN=http://localhost:11290
# Protects Swagger UI / spec in production (basic gate). Leave blank in dev.
API_DOCS_TOKEN=

# ── Web (frontend) ──────────────────────────────────────────────────
WEB_PORT=11290
# Base URL the browser uses to reach the API.
VITE_API_BASE_URL=http://localhost:11291

# ── Runtime ─────────────────────────────────────────────────────────
NODE_ENV=development
TZ=UTC
