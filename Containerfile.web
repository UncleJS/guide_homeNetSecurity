# NetInventory Web — production image (static React build served by Bun)
FROM docker.io/oven/bun:1 AS build
WORKDIR /app
COPY app/ ./
RUN bun install --frozen-lockfile || bun install
WORKDIR /app/web
# VITE_API_BASE_URL is baked at build time; override via build-arg if needed
ARG VITE_API_BASE_URL=http://localhost:11291
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN bun run build

FROM docker.io/oven/bun:1
WORKDIR /app/web
COPY --from=build /app/web/dist ./dist
COPY --from=build /app/web/serve.ts ./serve.ts
ENV NODE_ENV=production
EXPOSE 11290
CMD ["bun", "run", "serve.ts"]
