# Env — secrets live here, never commit
.env
**/.env
!.env.example
!**/.env.example

# Credentials & secret config — never commit anything holding user/password/keys
*.secret
*.secrets
secrets.*
**/secrets.*
*credential*
*credentials*
config.local.*
*.local.json
!tsconfig*.json
# Keys, certs, keystores
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.kdbx
.htpasswd

# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
build/
**/build/

# Bun
.bun/
bun.lockb.bak

# Logs & local data
*.log
logs/
*.sqlite
*.sqlite3

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Claude Code local/runtime state (locks, local settings)
.claude/
